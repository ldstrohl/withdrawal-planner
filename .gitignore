__pycache__/
*.pyc
.pytest_cache/
.venv/
/tmp/
*.egg-info/
.DS_Store
.claude/
# Scenario JSONs — only the canonical default is tracked. Personal/exported
# scenarios stay local. The app loads scenarios/default.local.json first if it
# exists, falling back to the tracked default.
scenarios/*.json
!scenarios/default.json
